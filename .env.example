# Copie este arquivo para ".env" e preencha com suas credenciais.
# Depois de editar o .env, reinicie o Expo (Ctrl+C e npx expo start).

# Chave da API do TMDB — crie a sua em https://www.themoviedb.org/settings/api
EXPO_PUBLIC_TMDB_API_KEY=cole_sua_chave_aqui

# URL base do seu projeto no MockAPI — confira o prefixo no painel!
# (pode ser /api/v1 ou o nome do projeto, ex: /catalogo-filmes)
EXPO_PUBLIC_MOCKAPI_URL=https://SEU_CODIGO.mockapi.io/SEU_PREFIXO
